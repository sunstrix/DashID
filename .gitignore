# ============================================================================
# DashID - Git Ignore
# ============================================================================
# Arquivos e diretórios ignorados pelo Git no projeto DashID.
# ============================================================================

# ============================================================================
# AMBIENTE VIRTUAL
# ============================================================================
venv/
env/
ENV/
.venv

# ============================================================================
# PYTHON - CACHE E COMPILADOS
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ============================================================================
# ARQUIVOS DE AMBIENTE E CREDENCIAIS
# ============================================================================
.env
.env.local
.env.*.local

# ============================================================================
# STREAMLIT
# ============================================================================
.streamlit/secrets.toml

# ============================================================================
# DADOS E ARQUIVOS TEMPORÁRIOS
# ============================================================================
data/
*.xlsx
*.xlsm
*.xls
*.csv
!requirements.txt

# Arquivos de exportação temporários
dashid_export.*
*.tmp
*.temp

# ============================================================================
# LOGS
# ============================================================================
*.log
logs/

# ============================================================================
# IDEs E EDITORES
# ============================================================================

# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================================
# ARQUIVOS DE SISTEMA
# ============================================================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes

# Linux
*~
.directory

# ============================================================================
