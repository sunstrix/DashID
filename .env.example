# ============================================================================
# DashID - Exemplo de Variaveis de Ambiente (TEMPLATE PARA GIT)
# ============================================================================
#
# Este arquivo e um MODELO. Copie para .env e preencha com suas credenciais.
#
# Para criar o arquivo .env no Windows (PowerShell):
#   Copy-Item .env.example .env
#
# IMPORTANTE:
# - NUNCA commite o arquivo .env com credenciais reais no Git!
# - O arquivo .env ja esta no .gitignore deste projeto.
# - As credenciais abaixo sao apenas exemplos ficticios.
#
# ============================================================================

# ============================================================================
# CONFIGURACOES DO MICROSOFT SHAREPOINT (OPCIONAL - GRAPH API FALLBACK)
# ============================================================================
# Estas variaveis sao usadas pelo modulo sharepoint_connector.py APENAS se
# o download direto do link de compartilhamento falhar e voce quiser habilitar
# o Microsoft Graph API como metodo avancado de autenticacao.
#
# O DASHID FUNCIONA PERFEITAMENTE SEM ESTAS VARIAVEIS - o download direto
# do link de compartilhamento (configurado em config.py) nao requer credenciais.
#
# Para obter essas credenciais:
# 1. Acesse o Azure Portal (https://portal.azure.com)
# 2. Va em "Azure Active Directory" > "App registrations" > "New registration"
# 3. Crie um novo app e anote o "Application (client) ID" -> CLIENT_ID
# 4. Va em "Certificates & secrets" > "New client secret" -> CLIENT_SECRET
# 5. Va em "API permissions" > "Add a permission" > "Microsoft Graph"
#    > "Application permissions" > "Files.Read.All" e "Sites.Read.All"
# 6. Clique em "Grant admin consent"
# 7. Para obter TENANT_ID: "Azure Active Directory" > "Overview" > "Tenant ID"
# 8. Para obter SITE_ID e DRIVE_ID, use a Graph API:
#    GET https://graph.microsoft.com/v1.0/sites/root
#    GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives

# ID do Tenant (Azure AD Directory ID)
SHAREPOINT_TENANT_ID=seu-tenant-id-aqui-exemplo-12345678-1234-1234-1234-123456789012

# ID do Aplicativo registrado no Azure AD (Client ID)
SHAREPOINT_CLIENT_ID=seu-client-id-aqui-exemplo-abcdef12-3456-7890-abcd-ef1234567890

# Secret do Aplicativo (gerado em "Certificates & secrets")
SHAREPOINT_CLIENT_SECRET=seu-client-secret-aqui-exemplo-abcdef1234567890abcdef1234567890abcdef12

# ID do Site do SharePoint (obtido via Graph API)
SHAREPOINT_SITE_ID=seu-site-id-aqui-exemplo-contoso.sharepoint.com,12345678-1234-1234-1234-123456789012,87654321-4321-4321-4321-210987654321

# ID do Drive (Document Library) onde a planilha esta armazenada
SHAREPOINT_DRIVE_ID=seu-drive-id-aqui-exemplo-b!abcdef1234567890abcdef1234567890abcdef1234567890

# Caminho relativo do arquivo dentro do Drive (a partir da raiz da biblioteca)
# Exemplo: "DashID/Relatorio_de_projecao_mes_julho_26.xlsx"
SHAREPOINT_FILE_PATH=DashID/Relatorio_de_projecao_mes_julho_26.xlsx

# ============================================================================
# CONFIGURACOES DO STREAMLIT (OPCIONAIS)
# ============================================================================
# Estas variaveis sobrescrevem as configuracoes padrao do Streamlit.
# Deixe em branco para usar os valores padrao.

# Porta do servidor Streamlit (padrao: 8501)
STREAMLIT_SERVER_PORT=8501

# Modo headless (true = nao abre navegador automaticamente)
STREAMLIT_SERVER_HEADLESS=false

# Endereco do servidor (padrao: localhost)
STREAMLIT_SERVER_ADDRESS=localhost

# Tema base (padrao: dark)
STREAMLIT_THEME_BASE=dark

# ============================================================================
# CONFIGURACOES DE LOG (OPCIONAIS)
# ============================================================================
# Controle o nivel de detalhamento dos logs do sistema.

# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL (padrao: INFO)
LOG_LEVEL=INFO

# Formato do log (padrao: %(asctime)s | %(levelname)-8s | %(name)s | %(message)s)
LOG_FORMAT=%(asctime)s | %(levelname)-8s | %(name)s | %(message)s

# Formato de data no log (padrao: %Y-%m-%d %H:%M:%S)
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# ============================================================================
# CONFIGURACOES DE NEGOCIO (OPCIONAIS - SOBRESCREVEM config.py)
# ============================================================================
# Estas variaveis permitem ajustar parametros de negocio sem modificar o codigo.
# Deixe em branco para usar os valores padrao definidos em config.py.

# Meta do ID (Indice de Identificacao) - Padrao: 1.15 (115%)
# Consulta de CPF do cliente no sistema
META_ID=1.15

# Threshold de performance alta - Padrao: 1.30 (130%)
PERFORMANCE_HIGH=1.30

# Threshold de performance media - Padrao: 1.20 (120%)
PERFORMANCE_MEDIUM=1.20

# Threshold de performance baixa - Padrao: 1.10 (110%)
PERFORMANCE_LOW=1.10

# Threshold de performance critica - Padrao: 1.00 (100%)
PERFORMANCE_CRITICAL=1.00

# Numero de dias consecutivos de queda para alerta - Padrao: 3
CONSECUTIVE_DROP_THRESHOLD=3

# Media movel curta (dias) - Padrao: 3
MOVING_AVERAGE_SHORT=3

# Media movel longa (dias) - Padrao: 7
MOVING_AVERAGE_LONG=7

# ============================================================================
# CONFIGURACOES DE CACHE (OPCIONAIS)
# ============================================================================
# TTL (Time To Live) em segundos para cache de dados.
# Use 0 para cache permanente (ate o arquivo ser recarregado).

# TTL do cache de dados (padrao: 0)
CACHE_DATA_TTL=0

# TTL do cache de analises (padrao: 0)
CACHE_ANALYTICS_TTL=0

# TTL do cache do SharePoint (padrao: 3600 = 1 hora)
CACHE_SHAREPOINT_TTL=3600

# ============================================================================
# CONFIGURACOES DE DESENVOLVIMENTO (OPCIONAIS)
# ============================================================================
# Ativadas apenas durante desenvolvimento/debugging.

# Modo debug (true = mostra mais informacoes na interface)
DEBUG_MODE=false

# Mostrar indicador de cache do Streamlit (padrao: false)
SHOW_CACHE_INDICATOR=false

# ============================================================================
# NOTAS DE USO
# ============================================================================
#
# 1. O dashID funciona com o arquivo .env VAZIO (apenas com valores padrao).
#
# 2. O download do SharePoint via link de compartilhamento (config.py) 
#    NAO requer credenciais - funciona automaticamente.
#
# 3. As credenciais do SharePoint (TENANT_ID, CLIENT_ID, etc.) sao APENAS
#    para o fallback via Microsoft Graph API quando necessario.
#
# 4. Este arquivo (.env.example) DEVE ser commitado no Git, pois serve
#    como referencia para a equipe configurar suas proprias variaveis.
#
# 5. Para criar um novo .env a partir deste exemplo:
#    Copy-Item .env.example .env
#
# ============================================================================